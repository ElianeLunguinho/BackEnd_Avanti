generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum NivelConhecimento {
  BASICO
  INTERMEDIARIO
  AVANCADO
}

model User {
  id            String         @id @default(uuid())
  nome          String         @db.VarChar(100)
  email         String         @unique
  phone         String
  descricao     String?
  conhecimentos Conhecimento[]

  @@map("users")
}

model Conhecimento {
  id                 String            @id @default(uuid())
  tituloConhecimento String            @db.VarChar(300)
  descricao          String
  nivel              NivelConhecimento

  user   User   @relation(fields: [userId], references: [id])
  userId String

  @@map("conhecimentos")
}